/target
# rust-analyzer / per-crate cargo invocations leave a target/ dir
# inside whichever crate they ran from; ignore at any depth.
**/target/
/.cargo/
/.env
/.wrangler/
/.claude/settings.local.json
/.sisyphus/evidence/
/.sisyphus/boulder.json
/.omc/
/.superpowers/
assay-workflow.db
assay-workflow.db-*

# Local engine config + per-module SQLite scratch files
/engine.toml
/engine.local.toml
/data/

# Build output — generated by: assay site/build.lua
/build/

# moon's local task-output cache + state. Workspace + project configs
# (.moon/workspace.yml, .moon/toolchain.yml, .moon/tasks/*) ARE
# committed; the cache + state directories are per-developer and
# per-CI-run.
/.moon/cache/
/.moon/docker/

# Playwright e2e artefacts. node_modules + browsers are installed by
# CI on demand; test results + traces are per-run.
/crates/assay-workflow/tests-e2e/node_modules/
/crates/assay-workflow/tests-e2e/test-results/
/crates/assay-workflow/tests-e2e/playwright-report/
/crates/assay-workflow/tests-e2e/.last-run.json

# E2E SQLite scratch dirs created when local runs use a CWD-relative
# data_dir. CI fixtures explicitly point at /tmp, but a developer
# launching the engine binary directly from these directories will
# land here (auth.db / engine.db / workflow.db).
/crates/assay-engine/tests-e2e/data/
/crates/assay-workflow/tests-e2e/data/

# OMC session state in nested dirs
**/.omc/
/crates/assay-engine/tests-e2e/node_modules/
/crates/assay-engine/tests-e2e/test-results/
/crates/assay-engine/tests-e2e/playwright-report/
/libs/sysops/tests-e2e/node_modules/
/libs/sysops/tests-e2e/test-results/
/libs/sysops/tests-e2e/playwright-report/
